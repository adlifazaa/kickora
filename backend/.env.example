# Required — API-Football key (never commit the real value)
API_FOOTBALL_KEY=your_api_football_key_here

# Optional aliases (same value)
# KICKORA_API_FOOTBALL_KEY=

# Server
PORT=8080

# Rate limit: max requests per IP per window (default 120 / 15 min)
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=900000

# Set true if you need browser/CORS access during testing
ENABLE_CORS=false

# Trust X-Forwarded-For when behind Railway/Render/Fly proxy
TRUST_PROXY=true
