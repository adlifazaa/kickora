# Required — API-Football key (never commit the real value)
API_FOOTBALL_KEY=your_api_football_key_here

# Optional aliases (same value)
# KICKORA_API_FOOTBALL_KEY=

# Optional — NewsAPI key for GET /news/world-cup (never commit the real value)
# NEWS_API_KEY=your_newsapi_key_here

# Server
PORT=8080

# Rate limit: max requests per IP per window (default 120 / 15 min)
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=900000

# Set true if you need browser/CORS access during testing
ENABLE_CORS=false

# Trust X-Forwarded-For when behind Railway/Render/Fly proxy
TRUST_PROXY=true

# --- Live match notification worker (Phase 1 — DRY_RUN by default) ---
# Set true to start polling API-Football for live events
NOTIFICATIONS_ENABLED=false
# When true, log would-send payloads instead of calling FCM (safe default)
NOTIFICATIONS_DRY_RUN=true
# Poll interval for live fixtures (seconds) — default 120 to protect API quota
NOTIFICATIONS_POLL_SECONDS=120
# Max event API calls per worker poll cycle
# NOTIFICATIONS_MAX_EVENT_CALLS=15
# World Cup league id for notification event priority
# NOTIFICATIONS_WC_LEAGUE_ID=1
# Daily upstream API-Football budget before quota protection (default 6000)
# USAGE_DAILY_THRESHOLD=6000
# Poll interval when quota protection active (seconds, default 300)
# USAGE_PROTECTION_POLL_SECONDS=300
# Dedup TTL for sent notification keys (seconds, default 6h)
# NOTIFICATIONS_DEDUP_TTL_SECONDS=21600
# Max dry-run log entries kept in memory
# NOTIFICATIONS_DRY_RUN_LOG_MAX=200
# Firebase service account JSON (single line) — required only when
# NOTIFICATIONS_ENABLED=true AND NOTIFICATIONS_DRY_RUN=false
# FIREBASE_SERVICE_ACCOUNT_JSON=
